{
  "manifest_version": 3,
  "name": "Summarize AI - Advanced Web Content Recapper",
  "version": "1.4.0",
  "description": "High-performance AI summarization tool for web pages and text selections. Secure, private, and customizable. (dev build with quality improvements)",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "commands",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.aimlapi.com/*",
    "https://www.google-analytics.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://www.google-analytics.com; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "script.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "uninstall_url": "https://yourdomain.com/uninstall-feedback?ext=summarize-ai",
  "commands": {
    "summarize-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Summarize selected text"
    },
    "open-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Open Summarize AI popup"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "welcome.html",
        "icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}